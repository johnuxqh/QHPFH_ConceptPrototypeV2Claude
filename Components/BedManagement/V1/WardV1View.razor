@using QHPFH_ConceptPrototype.Components.BedManagement.Shared

<section class="bm-v1-view bm-v1-view--ward" aria-label="Ward V1 awareness view">
    <OperationalBanner Snapshot="@Snapshot" Message="@($"Ward awareness: focus on movement risks, discharge readiness, transfer concerns and constraints in {Ward.Name}.")" Tone="Awareness" />
    <div class="bm-v1-emphasis-table"><PerformanceTable Title="Movement blockers and readiness priorities" Rows="@AwarenessRows" /></div>
    <MetricTileRow Snapshot="@Snapshot" AwarenessMode="true" />
</section>

@code {
    [Parameter, EditorRequired] public Ward Ward { get; set; } = default!;
    private CapacitySnapshot Snapshot => BedManagementDemoData.GetWardSnapshot(Ward.Id)!;

    private IReadOnlyList<PerformanceRow> AwarenessRows => Ward.Beds
        .Where(IsAwarenessPriority)
        .OrderBy(GetPriority)
        .Take(6)
        .Select(bed => new PerformanceRow(bed.Label, GetIndicator(bed), GetStatus(bed), GetDetail(bed)))
        .ToArray();

    private static bool IsAwarenessPriority(Bed bed) =>
        bed.Discharge is not null || bed.Transfer is not null || bed.Status is BedStatus.PendingCleaning or BedStatus.Maintenance or BedStatus.Closed || bed.NextExpectedAction.Contains("Senior", StringComparison.OrdinalIgnoreCase);

    private static int GetPriority(Bed bed) => bed.Discharge?.Status switch
    {
        FlowStatus.Delayed => 0,
        FlowStatus.Ready => 1,
        _ when bed.Transfer is not null => 2,
        _ when bed.Status is BedStatus.Maintenance or BedStatus.Closed => 3,
        _ => 4
    };

    private static string GetIndicator(Bed bed)
    {
        if (bed.Discharge is { Status: FlowStatus.Ready }) return "Ready";
        if (bed.Discharge is { Status: FlowStatus.Delayed }) return "Delayed";
        if (bed.Discharge is not null) return "Planned";
        if (bed.Transfer is not null) return bed.Transfer.Status.ToString();
        return "Constraint";
    }

    private static string GetStatus(Bed bed)
    {
        if (bed.Discharge is not null) return "Discharge";
        if (bed.Transfer is not null) return "Transfer";
        if (bed.NextExpectedAction.Contains("Senior", StringComparison.OrdinalIgnoreCase)) return "Review";
        return "Constraint";
    }

    private static string GetDetail(Bed bed)
    {
        if (bed.Discharge is { } discharge) return $"EDD {discharge.PlannedTime} · {discharge.Barrier} · destination {discharge.Destination}";
        if (bed.Transfer is { } transfer) return $"{transfer.Direction} to {transfer.TargetWard} · requested {transfer.RequestedTime}";
        return bed.OperationalNote;
    }
}
