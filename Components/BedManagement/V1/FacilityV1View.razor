@using QHPFH_ConceptPrototype.Components.BedManagement.Shared

<section class="bm-v1-view bm-v1-view--facility" aria-label="Facility V1 awareness view">
    <OperationalBanner Snapshot="@Snapshot" Message="@($"Bed management awareness: scan ward pressure, discharge opportunity and flow blockers across {Facility.ShortName}.")" Tone="Awareness" />
    <div class="bm-v1-awareness-grid @(Facility.Signals.Count == 0 ? "bm-v1-awareness-grid--single" : null)">
        <div class="bm-v1-emphasis-table"><PerformanceTable Title="Ward pressure, opportunity and constraints" Rows="@WardRows" /></div>
        @if (Facility.Signals.Count > 0)
        {
            <InsightCardGrid Signals="@Facility.Signals" Version="@BedManagementVersion.V2Balanced" ContextLabel="V1 awareness" />
        }
    </div>
    <MetricTileRow Snapshot="@Snapshot" AwarenessMode="true" />
</section>

@code {
    [Parameter, EditorRequired] public Facility Facility { get; set; } = default!;
    private CapacitySnapshot Snapshot => BedManagementDemoData.GetFacilitySnapshot(Facility.Id)!;
    private IReadOnlyList<PerformanceRow> WardRows => Facility.Wards.Select(ward =>
    {
        var snapshot = BedManagementDemoData.GetWardSnapshot(ward.Id)!;
        var balance = snapshot.PlannedDischarges >= snapshot.ExpectedAdmissions ? "Discharge opportunity" : "Admission pressure";
        return new PerformanceRow(ward.Name, $"{snapshot.OccupancyPercentage}%", ward.EscalationStatus, $"{balance} · {snapshot.PlannedDischarges} planned discharges · {snapshot.TransferRequests} transfer concerns · {snapshot.ClosedBeds + snapshot.PendingMaintenance} constrained beds");
    }).OrderBy(row => row.Status == "BAU").ToArray();
}
